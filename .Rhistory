if (!is.null(nb_res)) {
vote_data <- as.integer(nb_res$Best.nc[1, ])
vote_data <- vote_data[is.finite(vote_data)]
vote_data <- vote_data[vote_data >= min_k & vote_data <= max_k]
k_raw <- as.integer(names(which.max(table(vote_data))))
} else {
sil <- sapply(seq(min_k, max_k), function(k) {
km <- kmeans(pca_data, centers = k, nstart = 25)
mean(silhouette(km$cluster, dist(pca_data))[, 3], na.rm = TRUE)
})
# -----------------------------
# SILHOUETTE RULE (MODE SWITCH)
# -----------------------------
if (strict_mode) {
k_raw <- which.max(sil) + 1
} else {
k_raw <- which.max(sil) + min_k - 1
}
message(group_label, " | NbClust failed, silhouette k =", k_raw)
}
# -----------------------------
# 5. Clamp k
# -----------------------------
k_opt <- max(min_k, min(k_raw, max_k))
rm(list = ls())
library(dplyr)
library(tidyr)
# Set seed for reproducibility
set.seed(42)
# Configuration
N_sites <- 30
S_species <- 3
periods <- c("Pre", "Trans", "Eq")
# True Parameters (Log scale)
# Sp 1: No change
# Sp 2: Gradual expansion
# Sp 3: Overshoot (Trans > Eq)
alpha <- c(2.0, 1.0, 0.5)
gamma_trans <- c(0.0, 0.8, 2.0)
gamma_eq    <- c(0.0, 1.5, 1.0)
phi <- c(5, 5, 5) # Overdispersion
# Generate Data
synthetic_data <- expand.grid(Site = 1:N_sites, Period = periods, Species_ID = 1:S_species) %>%
mutate(
# Dummy coding logic: 0,0 means Pre-suppression
d_trans = ifelse(Period == "Trans", 1, 0),
d_eq    = ifelse(Period == "Eq", 1, 0),
# Calculate expected mean (mu) using the SO2 equation
log_mu = alpha[Species_ID] +
gamma_trans[Species_ID] * d_trans +
gamma_eq[Species_ID] * d_eq,
mu = exp(log_mu),
# Draw counts from Negative Binomial
Count = rnbinom(n(), size = phi[Species_ID], mu = mu)
)
# Preview the 'Long Format' data
head(synthetic_data)
library(rstan)
# Prepare data list for Stan
stan_data <- list(
N = nrow(synthetic_data),
S = S_species,
y = synthetic_data$Count,
sp_id = synthetic_data$Species_ID,
d_trans = synthetic_data$d_trans,
d_eq = synthetic_data$d_eq
)
# Fit the model
fit <- stan(file = 'so2_model.stan', data = stan_data, chains = 4, iter = 2000)
# Print results to see if they match our 'True' parameters
print(fit, pars = c("alpha", "gamma_trans", "gamma_eq"))
library(tidybayes)
library(ggplot2)
library(dplyr)
library(tidyr)
# 1. Extract and transform the posterior to real-world abundance (exp scale)
# We calculate: Pre = exp(alpha), Trans = exp(alpha + g_trans), Eq = exp(alpha + g_eq)
trajectories <- fit %>%
spread_draws(alpha[Species_ID], gamma_trans[Species_ID], gamma_eq[Species_ID]) %>%
mutate(
Pre = exp(alpha),
Trans = exp(alpha + gamma_trans),
Eq = exp(alpha + gamma_eq)
) %>%
pivot_longer(cols = c(Pre, Trans, Eq), names_to = "Period", values_to = "Abundance") %>%
mutate(Period = factor(Period, levels = c("Pre", "Trans", "Eq")))
# 2. Plot the trajectories
ggplot(trajectories, aes(x = Period, y = Abundance, color = factor(Species_ID), fill = factor(Species_ID), group = Species_ID)) +
# Draw the 95% Credible Interval as a ribbon
stat_summary(fun.data = median_qi, geom = "ribbon", alpha = 0.1, color = NA) +
# Draw the median line
stat_summary(fun = median, geom = "line", size = 1.2) +
# Draw the median points
stat_summary(fun = median, geom = "point", size = 3) +
scale_y_log10() +
theme_minimal() +
labs(title = "Species Reassembly Trajectories (SO2)",
subtitle = "Lines show medians; Shaded areas show 95% credible intervals",
y = "Expected Abundance (log scale)",
x = "Suppression Period",
color = "Species",
fill = "Species")
# 1. Extract gamma parameters
gamma_plot <- fit %>%
spread_draws(gamma_trans[Species_ID], gamma_eq[Species_ID]) %>%
pivot_longer(cols = c(gamma_trans, gamma_eq), names_to = "Shift_Type", values_to = "Value")
# 2. Create the dot-whisker plot
ggplot(gamma_plot, aes(x = Value, y = factor(Species_ID), color = Shift_Type)) +
geom_vline(xintercept = 0, linetype = "dashed", alpha = 0.5) +
stat_pointinterval(.width = c(.66, .95), position = position_dodge(width = 0.5)) +
theme_minimal() +
labs(title = "Posterior Estimates of Reassembly Shifts",
subtitle = "Values > 0 indicate expansion relative to pre-suppression",
x = "Log-Abundance Shift (gamma)",
y = "Species ID",
color = "Shift Period")
rm(list = ls())
library(dplyr)
library(tidyr)
# Set seed for reproducibility
set.seed(42)
# Configuration
N_sites <- 30
S_species <- 3
periods <- c("Pre", "Trans", "Eq")
# True Parameters (Log scale)
# Sp 1: No change
# Sp 2: Gradual expansion
# Sp 3: Overshoot (Trans > Eq)
alpha <- c(2.0, 1.0, 0.5)
gamma_trans <- c(0.0, 0.8, 2.0)
gamma_eq    <- c(0.0, 1.5, 1.0)
phi <- c(5, 5, 5) # Overdispersion
# Generate Data
synthetic_data <- expand.grid(Site = 1:N_sites, Period = periods, Species_ID = 1:S_species) %>%
mutate(
# Dummy coding logic: 0,0 means Pre-suppression
d_trans = ifelse(Period == "Trans", 1, 0),
d_eq    = ifelse(Period == "Eq", 1, 0),
# Calculate expected mean (mu) using the SO2 equation
log_mu = alpha[Species_ID] +
gamma_trans[Species_ID] * d_trans +
gamma_eq[Species_ID] * d_eq,
mu = exp(log_mu),
# Draw counts from Negative Binomial
Count = rnbinom(n(), size = phi[Species_ID], mu = mu)
)
# Preview the 'Long Format' data
head(synthetic_data)
library(rstan)
# Prepare data list for Stan
stan_data <- list(
N = nrow(synthetic_data),
S = S_species,
y = synthetic_data$Count,
sp_id = synthetic_data$Species_ID,
d_trans = synthetic_data$d_trans,
d_eq = synthetic_data$d_eq
)
# Fit the model
fit <- stan(file = 'so2_model.stan', data = stan_data, chains = 4, iter = 2000)
